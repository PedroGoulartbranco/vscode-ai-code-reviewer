{
  "name": "vscode-ai-code-reviewer",
  "displayName": "ai-code-reviewer",
  "description": "An AI-powered code reviewer that identifies bugs and suggests optimizations.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ai-code-reviewer",
        "title": "Reviewer Code"
      }
    ],
    "configuration": {
      "title": "AI Reviewer Configuration",
      "properties": {
        "aiReviewer.apiKey": {
          "type": "string",
          "default": "",
          "description": "Enter your Gemini API Key to enable code review features."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.115.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1"
  }
}
